# Moderation Service Configuration
# Copy this file to .env and update values as needed for local development

# JWT Secret (must match auth service JWT_SECRET)
JWT_SECRET=your-jwt-secret-here

# Port the service runs on
MOD_SERVICE_PORT=6633

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

API_LAYER_URL=http://127.0.0.1:2745/v1

# Database connection settings
MOD_DB_HOST=localhost
MOD_DB_PORT=5434
MOD_DB_NAME=mod
MOD_DB_USER=mod_user
MOD_DB_PASSWORD=modpass
